<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-gray-50 flex flex-col min-h-screen font-sans text-gray-900">

    <%- include('partials/navbar') %>

        <main class="flex-grow max-w-5xl mx-auto px-4 py-16 w-full">

            <div class="text-center mb-12">
                <h1 class="text-4xl md:text-5xl font-extrabold text-black mb-4 tracking-tight">
                    Keahlian & Teknologi</h1>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Kombinasi antara logika pemrograman, pengolahan data, dan pemahaman
                    infrastruktur perangkat keras untuk menciptakan solusi yang komprehensif.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                <div
                    class="bg-white p-8 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition duration-300">
                    <div class="flex items-center mb-6">
                        <svg class="w-8 h-8 text-black mr-3" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                        </svg>
                        <h2 class="text-2xl font-bold text-black">Web Development</h2>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <span
                            class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">HTML/CSS</span>
                        <span
                            class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">JavaScript</span>
                        <span
                            class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">Node.js</span>
                        <span
                            class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">Express.js</span>
                        <span
                            class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">Tailwind
                            CSS</span>
                        <span
                            class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">Bootstrap
                            5</span>
                    </div>
                </div>

                <div
                    class="bg-white p-8 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition duration-300">
                    <div class="flex items-center mb-6">
                        <svg class="w-8 h-8 text-black mr-3" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z">
                            </path>
                        </svg>
                        <h2 class="text-2xl font-bold text-black">Software & Data</h2>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <span
                            class="bg-gray-100 text-gray-800 border border-gray-300 px-4 py-2 rounded-lg text-sm font-medium">MySQL</span>
                        <span
                            class="bg-gray-100 text-gray-800 border border-gray-300 px-4 py-2 rounded-lg text-sm font-medium">Python</span>
                        <span
                            class="bg-gray-100 text-gray-800 border border-gray-300 px-4 py-2 rounded-lg text-sm font-medium">Pandas
                            (Data Cleansing)</span>
                        <span
                            class="bg-gray-100 text-gray-800 border border-gray-300 px-4 py-2 rounded-lg text-sm font-medium">Tkinter
                            (GUI)</span>
                        <span
                            class="bg-gray-100 text-gray-800 border border-gray-300 px-4 py-2 rounded-lg text-sm font-medium">Ms.
                            Excel (Advanced & VBA)</span>
                    </div>
                </div>

                <div
                    class="bg-white p-8 rounded-2xl shadow-sm border border-gray-200 hover:shadow-md transition duration-300 md:col-span-2">
                    <div class="flex items-center mb-6">
                        <svg class="w-8 h-8 text-black mr-3" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01">
                            </path>
                        </svg>
                        <h2 class="text-2xl font-bold text-black">IT Infrastructure & Lainnya</h2>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <span
                            class="bg-white text-black border border-black px-4 py-2 rounded-lg text-sm font-medium">System
                            Administration</span>
                        <span
                            class="bg-white text-black border border-black px-4 py-2 rounded-lg text-sm font-medium">PC
                            Hardware and Software Configuration</span>
                        <span
                            class="bg-white text-black border border-black px-4 py-2 rounded-lg text-sm font-medium">IT
                            Support</span>
                    </div>
                </div>

            </div>
        </main>

        <%- include('partials/footer') %>

</body>

</html>