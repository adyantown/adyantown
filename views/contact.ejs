<%- include('partials/header') %>

    <%- include('partials/navbar') %>

        <main class="flex-grow max-w-5xl mx-auto px-4 py-16 w-full flex items-center">

            <div
                class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden flex flex-col md:flex-row w-full">

                <div
                    class="md:w-5/12 bg-black text-white p-10 md:p-12 flex flex-col justify-between">
                    <div>
                        <h1 class="text-3xl md:text-4xl font-extrabold mb-6 tracking-tight">Mari
                            Terhubung.</h1>
                        <p class="text-gray-400 leading-relaxed mb-10 text-sm">
                            Tertarik untuk berkolaborasi, berdiskusi tentang pengembangan sistem,
                            atau sekadar menyapa? Jangan ragu untuk mengirim pesan melalui formulir
                            di samping.
                        </p>

                        <div class="space-y-6">
                            <div class="flex items-start">
                                <svg class="w-6 h-6 mr-4 text-gray-500 mt-0.5" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z">
                                    </path>
                                </svg>
                                <div>
                                    <h3 class="text-sm font-semibold text-white">Lokasi</h3>
                                    <p class="text-sm text-gray-400">Tulang Bawang Barat, Lampung
                                    </p>
                                </div>
                            </div>

                            <div class="flex items-start">
                                <svg class="w-6 h-6 mr-4 text-gray-500 mt-0.5" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                                    </path>
                                </svg>
                                <div>
                                    <h3 class="text-sm font-semibold text-white">Email</h3>
                                    <p class="text-sm text-gray-400">adya718@gmail.com</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-12 pt-8 border-t border-gray-800">
                        <p
                            class="text-xs text-gray-500 mb-4 uppercase tracking-wider font-semibold">
                            Tautan Lainnya</p>
                        <div class="flex space-x-4">
                            <a href="https://www.linkedin.com/in/adyantown/"
                                class="text-gray-400 hover:text-white transition duration-300 text-sm font-medium">LinkedIn</a>
                            <a href="https://github.com/adyantown"
                                class="text-gray-400 hover:text-white transition duration-300 text-sm font-medium">GitHub</a>

                        </div>
                    </div>
                </div>

                <div class="md:w-7/12 p-10 md:p-12">
                    <form action="#" method="POST" class="space-y-6">
                        <div>
                            <label for="name"
                                class="block text-sm font-medium text-gray-700 mb-2">Nama
                                Lengkap</label>
                            <input type="text" id="name" name="name"
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition duration-300"
                                placeholder="Masukkan nama Anda" required>
                        </div>

                        <div>
                            <label for="email"
                                class="block text-sm font-medium text-gray-700 mb-2">Alamat
                                Email</label>
                            <input type="email" id="email" name="email"
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition duration-300"
                                placeholder="nama@email.com" required>
                        </div>

                        <div>
                            <label for="message"
                                class="block text-sm font-medium text-gray-700 mb-2">Pesan</label>
                            <textarea id="message" name="message" rows="5"
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition duration-300 resize-none"
                                placeholder="Tuliskan pesan atau tujuan Anda di sini..."
                                required></textarea>
                        </div>

                        <button type="submit"
                            class="w-full bg-black hover:bg-gray-800 text-white font-bold py-3 px-4 rounded-lg transition duration-300 shadow-md">
                            Kirim Pesan
                        </button>
                    </form>
                </div>

            </div>

        </main>

        <%- include('partials/footer') %>

</body>

</html>